<div class="card">
  <div class="card-header">
    <h2>Danh sách sản phẩm</h2>
    <form class="search-form" method="get" action="/products">
      <input type="text" name="q" placeholder="Tìm theo tên" value="<%= searchText %>" />
      <button class="btn" type="submit">Tìm kiếm</button>
    </form>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Hình ảnh</th>
          <th>Tên</th>
          <th>Giá</th>
          <th>Số lượng</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!products.length) { %>
          <tr>
            <td colspan="5" class="text-center">Chưa có sản phẩm</td>
          </tr>
        <% } %>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>" class="thumb" />
              <% } else { %>
                <span class="muted">Không có hình</span>
              <% } %>
            </td>
            <td><%= product.name %></td>
            <td><%= product.price.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }) %></td>
            <td><%= product.quantity %></td>
            <td class="actions">
              <a class="btn" href="/products/<%= product.id %>/edit">Sửa</a>
              <form method="post" action="/products/<%= product.id %>?_method=DELETE" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                <button class="btn danger" type="submit">Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
